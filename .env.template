# FastAPI Settings
HOST=127.0.0.1
PORT=8000

# NVIDIA NIM API Settings
# Get your free credits & API key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Pipeline Models Configuration
# Story Model Choices: nvidia/llama-3.1-nemotron-70b-instruct, qwen/qwen2.5-72b-instruct
STORY_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Image Generation Models
# Character model represents Qwen-Image for base concept generation
CHARACTER_MODEL=qwen-image
# Edit model represents Qwen-Image-Edit for scene-to-scene editing & consistency
EDIT_MODEL=qwen-image-edit

# Hugging Face Settings (Fallback Image Models)
# Get your free token at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Voice Generation settings
# TTS_PROVIDER can be "chatterbox" or "edge-tts"
TTS_PROVIDER=chatterbox
# Voice option for Edge-TTS fallback (e.g. en-US-ChristopherNeural, en-US-JennyNeural)
DEFAULT_VOICE=en-US-ChristopherNeural
